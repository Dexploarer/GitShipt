{
  "name": "gitbags",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "theme:export": "node scripts/theme-export.mjs",
    "theme:lint": "node scripts/theme-lint.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.3.7",
    "@hookform/resolvers": "^3.9.1",
    "@neondatabase/serverless": "^0.10.4",
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "better-auth": "^1.6.9",
    "bs58": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "tweetnacl": "^1.0.3",
    "workflow": "^4.2.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4",
    "@types/bs58": "^4.0.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^2.1.8",
    "axe-playwright": "^2.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.13.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
