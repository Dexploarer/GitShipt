# GitShipt production environment template
# Do not populate this file with real values. Use it as the input checklist for
# Vercel Production env vars. Mark every *_KEY, *_SECRET, *PRIVATE_KEY,
# *KEYPAIR, POSTGRES_URL, DATABASE_URL, REDIS_URL, UPSTASH_*,
# and HELIUS_RPC_URL value as Sensitive.

# ---- App ----
NEXT_PUBLIC_APP_URL=https://gitshipt.com
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# ---- Database (Neon Postgres) ----
# Server-only. Do not expose Postgres URLs with NEXT_PUBLIC_*.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ---- Redis ----
REDIS_URL=
UPSTASH_REDIS_REST_REDIS_URL=

# ---- Auth ----
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://gitshipt.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth callback URL: https://gitshipt.com/api/auth/callback/github

# ---- GitHub App ----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=
# GitHub App webhook URL: https://gitshipt.com/api/webhooks/github

# ---- Bags.fm ----
BAGS_API_KEY=
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1/
BAGS_WEBHOOK_SECRET=
BAGS_PARTNER_WALLET=HXs58Qa6YtgJfWVkQVnpFmw6WoEdFEL4LLD1ArZjMvTH
BAGS_PARTNER_CONFIG_KEY=
BAGS_REF_CODE=symbiex
BAGS_CONFIG_TYPE=
BAGS_ALLOW_PROD_LAUNCH=false
ALLOW_STUBS_IN_PROD=false

# ---- Solana ----
HELIUS_RPC_URL=
SOLANA_PAYOUT_KEYPAIR=
SOLANA_TREASURY_ADDRESS=

# ---- Cron ----
# Generate: openssl rand -base64 32   (32+ chars enforced)
CRON_SECRET=

# ---- Idempotency ----
# Generate: openssl rand -base64 32   (32+ chars enforced)
# HMAC key that signs every cached idempotency response.
IDEMPOTENCY_KEY_SECRET=

# ---- Platform ----
PLATFORM_FEE_BPS_DEFAULT=500
ADMIN_EMAIL_ALLOWLIST=
KILL_SWITCH_ENABLED=false

# Out-of-band emergency stop. true => every trading-controls entry returns halted.
EMERGENCY_KILL_SWITCH=false

# Hard gate on non-prod-only utilities. Must be false in production.
ALLOW_DEMO_SEED=false
ALLOW_NON_NEON_RLS_OFF=false
