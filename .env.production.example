# GitBags production environment template
# Do not populate this file with real values. Use it as the input checklist for
# Vercel Production env vars. Mark every *_KEY, *_SECRET, *PRIVATE_KEY,
# *KEYPAIR, DATABASE_URL, REDIS_URL, and HELIUS_RPC_URL value as Sensitive.

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-gitbags-domain.example
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# ---- Database ----
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ---- Redis ----
REDIS_URL=

# ---- Auth ----
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-gitbags-domain.example
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- GitHub App ----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# ---- Bags.fm ----
BAGS_API_KEY=
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1/
BAGS_WEBHOOK_SECRET=
BAGS_PARTNER_WALLET=HXs58Qa6YtgJfWVkQVnpFmw6WoEdFEL4LLD1ArZjMvTH
BAGS_PARTNER_CONFIG_KEY=
BAGS_REF_CODE=symbiex
BAGS_CONFIG_TYPE=
BAGS_ALLOW_PROD_LAUNCH=false
ALLOW_STUBS_IN_PROD=false

# ---- Solana ----
HELIUS_RPC_URL=
SOLANA_PAYOUT_KEYPAIR=
SOLANA_TREASURY_ADDRESS=

# ---- Cron ----
CRON_SECRET=

# ---- Platform ----
PLATFORM_FEE_BPS_DEFAULT=500
ADMIN_EMAIL_ALLOWLIST=
KILL_SWITCH_ENABLED=false
