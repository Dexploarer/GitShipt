{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "bunVersion": "1.3.12",
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run build",
  "devCommand": "bun run dev -- --port $PORT",
  "outputDirectory": "apps/web/.next",
  "fluid": true,
  "regions": ["iad1"],
  "functions": {
    "apps/web/app/api/cron/**/*.ts": {
      "maxDuration": 800
    },
    "apps/web/app/api/webhooks/**/*.ts": {
      "maxDuration": 60
    },
    "apps/web/app/api/projects/[id]/launch/route.ts": {
      "maxDuration": 300
    },
    "apps/web/app/api/projects/[id]/reindex/route.ts": {
      "maxDuration": 300
    },
    "apps/web/app/api/admin/refresh-contributors/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/cron/index-github", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/snapshot", "schedule": "0 0 * * *" },
    { "path": "/api/cron/payout", "schedule": "30 0 * * *" },
    { "path": "/api/cron/expire-escrow", "schedule": "0 1 * * *" },
    { "path": "/api/cron/health", "schedule": "* * * * *" },
    { "path": "/api/cron/publish-kpis", "schedule": "* * * * *" }
  ]
}
